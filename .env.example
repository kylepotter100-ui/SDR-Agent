# Anthropic — Sonnet 4.6 for personalisation, Opus 4.7 for ranking
ANTHROPIC_API_KEY=

# Companies House Public Data API — HTTP Basic, key as username, empty password
COMPANIES_HOUSE_API_KEY=

# Google Places — findPlaceFromText for website and Facebook detection
GOOGLE_PLACES_API_KEY=

# Apollo — director email enrichment via the Apollo REST API
APOLLO_API_KEY=

# Resend — Monday digest email send to Kyle
RESEND_API_KEY=

# Supabase — runtime client (service role; full DB access from the agent)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cron protection — required as Authorization: Bearer header on /api/cron/*
CRON_SECRET=

# Where the Monday digest is delivered
DIGEST_RECIPIENT_EMAIL=kyle.potter@kpsolutions.io
